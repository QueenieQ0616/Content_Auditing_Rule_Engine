  {
    "rule_id": "AD_REGEX_WECHAT",
    "name": "微信号/微信模式",
    "level": "L3",
    "weight": 0.95,
    "logic": "OR",
    "conditions": [
      { "type": "regex", "value": "微信[号]?[:：]?[a-zA-Z0-9_-]+" },
      { "type": "regex", "value": "[加＋][Vv][信微]?" },
      { "type": "regex", "value": "vx[:：]?[a-zA-Z0-9]+" },
      { "type": "regex", "value": "微信号[:：]?\\S+" }
    ]
  },
  {
    "rule_id": "AD_REGEX_QQ",
    "name": "QQ号/QQ群",
    "level": "L3",
    "weight": 0.95,
    "conditions": [
      { "type": "regex", "value": "QQ[:：]?[0-9]{5,11}" },
      { "type": "regex", "value": "[群裙峮]?号[:：]?[0-9]{5,11}" },
      { "type": "regex", "value": "[加＋]QQ[:：]?[0-9]+" }
    ]
  },
  {
    "rule_id": "AD_REGEX_PHONE",
    "name": "手机号",
    "level": "L3",
    "weight": 0.95,
    "conditions": [
      { "type": "regex", "value": "1[3-9]\\d{9}" }
    ]
  },
  {
    "rule_id": "AD_COMBO_FREE_ACTION",
    "name": "免费+动作组合",
    "level": "L3",
    "weight": 0.9,
    "logic": "AND",
    "conditions": [
      { "type": "keyword", "value": ["免费", "限时", "优惠", "领"] },
      { "type": "keyword", "value": ["加", "联系", "扫码", "点击", "私"] }
