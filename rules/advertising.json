  },
  {
    "rule_id": "AD_COMBO_GROUP_INDUCE",
    "name": "群号+诱导语",
    "level": "L3",
    "weight": 0.9,
    "logic": "OR",
    "conditions": [
      { "type": "regex", "value": "[群裙峮]?号[:：]?\\d+" },
      { "type": "regex", "value": "[群裙峮]+[号]?[:：]?\\d+" }
    ]
  },
  {
    "rule_id": "AD_COMBO_MONEY_ACTION",
