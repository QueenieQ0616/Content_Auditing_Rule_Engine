  "components": {
    "schemas": {
      "AuthRequest": {
        "properties": {
          "username": {
            "type": "string",
            "maxLength": 32,
            "minLength": 3,
            "pattern": "^[A-Za-z0-9_\\-\\u4e00-\\u9fa5]+$",
            "title": "Username"
          },
          "password": {
            "type": "string",
            "maxLength": 64,
            "minLength": 6,
            "title": "Password"
          }
        },
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "title": "AuthRequest"
      },
      "BatchReviewRequest": {
        "properties": {
          "contents": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "maxItems": 500,
            "minItems": 1,
            "title": "Contents"
          },
          "scale": {
            "type": "string",
            "pattern": "^(loose|standard|strict)$",
            "title": "Scale",
            "default": "standard"
          },
          "biz_type": {
            "type": "string",
            "title": "Biz Type",
            "default": "default"
          }
        },
        "type": "object",
        "required": [
          "contents"
        ],
        "title": "BatchReviewRequest"
      },
      "ContentRequest": {
        "properties": {
          "content": {
            "type": "string",
            "maxLength": 10000,
            "minLength": 1,
            "title": "Content"
          },
          "scale": {
            "type": "string",
            "pattern": "^(loose|standard|strict)$",
            "title": "Scale",
            "default": "standard"
          },
          "biz_type": {
            "type": "string",
            "title": "Biz Type",
            "default": "default"
          }
        },
        "type": "object",
        "required": [
          "content"
        ],
        "title": "ContentRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ManualReviewRequest": {
        "properties": {
          "task_id": {
            "type": "string",
            "title": "Task Id"
          },
          "decision": {
            "type": "string",
            "pattern": "^(pass|review|reject)$",
            "title": "Decision"
          },
          "reviewer": {
            "type": "string",
            "minLength": 1,
            "title": "Reviewer"
          },
          "comment": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Comment",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "task_id",
          "decision",
          "reviewer"
        ],
        "title": "ManualReviewRequest"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "string",
            "description": "错误说明"
          }
        },
        "required": [
          "detail"
        ]
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "Token",
        "description": "登录或注册后返回的 Token，格式为 Authorization: Bearer <token>"
      }
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "本地开发环境"
    }
  ],
  "tags": [
    {
      "name": "健康检查",
      "description": "服务健康状态检查"
    },
    {
      "name": "账号管理",
      "description": "账号注册、登录、当前用户和退出登录"
    },
    {
      "name": "内容审核",
      "description": "单条审核、批量审核和审核历史"
    },
    {
      "name": "命中过程",
      "description": "规则与关键词命中过程分析"
    },
    {
      "name": "规则管理",
      "description": "公开规则列表查询"
    },
    {
      "name": "人工审核",
      "description": "人工审核任务列表、详情和处理"
    },
    {
      "name": "统计",
      "description": "审核统计数据"
    },
    {
      "name": "数据管理",
      "description": "运行时数据清空"
    }
  ]
